---
import Base from '../layouts/Base.astro';
import { getCollection } from 'astro:content';

const allPosts = (await getCollection('blog')).sort(
  (a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
);

const byYear = allPosts.reduce((acc, post) => {
  const year = post.data.date.slice(0, 4);
  if (!acc[year]) acc[year] = [];
  acc[year].push(post);
  return acc;
}, {});

const years = Object.keys(byYear).sort((a, b) => Number(b) - Number(a));
const monthNames = ['','Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];
---
<Base title="Memoria">
<style is:global>
  .mem-wrap { padding: 3rem 0; }
  .mem-header { margin-bottom: 3rem; padding-bottom: 1.5rem; border-bottom: 1px solid var(--rule); }
  .mem-title { font-size: 2.2rem; font-style: italic; font-weight: 400; }
  .mem-sub { font-size: 0.82rem; color: var(--ink-faint); font-style: italic; margin-top: 0.3rem; margin-bottom: 0; }

  .timeline { position: relative; padding-left: 2rem; max-width: 660px; }
  .timeline::before { content: ''; position: absolute; left: 0; top: 0; bottom: 0; width: 1px; background: var(--rule); }

  .year-block { margin-bottom: 2.5rem; position: relative; }
  .year-label { font-size: 1.4rem; font-style: italic; font-weight: 400; color: var(--ink-muted); margin-bottom: 1rem; position: relative; }
  .year-label::before { content: ''; position: absolute; left: -2.45rem; top: 50%; transform: translateY(-50%); width: 9px; height: 9px; border-radius: 50%; background: var(--paper); border: 1.5px solid var(--ink-muted); }

  .month-block { margin-bottom: 1rem; }
  .month-label { font-size: 0.68rem; letter-spacing: 0.14em; text-transform: uppercase; color: var(--ink-faint); margin-bottom: 0.4rem; padding-left: 0.6rem; }

  .tl-post { display: flex; align-items: baseline; gap: 0.8rem; padding: 0.5rem 0.7rem; border-radius: 2px; text-decoration: none; color: inherit; transition: background 0.15s, padding-left 0.2s; position: relative; }
  .tl-post::before { content: ''; position: absolute; left: -2.3rem; top: 52%; transform: translateY(-50%); width: 5px; height: 5px; border-radius: 50%; background: var(--paper-dark); border: 1px solid var(--rule); transition: all 0.15s; }
  .tl-post:hover { background: var(--paper-dark); padding-left: 1rem; }
  .tl-post:hover::before { background: var(--accent); border-color: var(--accent); }

  .tl-dot { width: 6px; height: 6px; border-radius: 50%; flex-shrink: 0; margin-top: 0.5rem; opacity: 0.75; }
  .tl-dot.lucid { background: var(--lucid); }
  .tl-dot.drift  { background: var(--drift); }

  .tl-body { flex: 1; min-width: 0; }
  .tl-title { font-size: 0.95rem; font-style: italic; display: block; }
  .tl-desc { font-size: 0.78rem; color: var(--ink-muted); margin-top: 0.1rem; display: block; line-height: 1.4; }

  .tl-meta { display: flex; flex-direction: column; align-items: flex-end; flex-shrink: 0; gap: 3px; }
  .tl-date { font-size: 0.75rem; color: var(--ink-faint); white-space: nowrap; }
  .pin-mark { font-size: 0.65rem; color: var(--ink-faint); margin-right: 3px; }
</style>

<div class="mem-wrap">
  <div class="mem-header">
    <h1 class="mem-title">Memoria</h1>
    <p class="mem-sub">all {allPosts.length} entries — in the order they happened</p>
  </div>

  <div class="timeline">
    {years.map(year => {
      const postsInYear = byYear[year];
      const byMonth = postsInYear.reduce((acc, post) => {
        const m = post.data.date.slice(0, 7);
        if (!acc[m]) acc[m] = [];
        acc[m].push(post);
        return acc;
      }, {});
      const months = Object.keys(byMonth).sort((a, b) => b.localeCompare(a));
      return (
        <div class="year-block">
          <div class="year-label">{year}</div>
          {months.map(month => (
            <div class="month-block">
              <div class="month-label">{monthNames[parseInt(month.slice(5))]}</div>
              {byMonth[month].map(post => {
                const slug = post.id.replace(/\.md$/, '');
                return (
                  <a href={'/memoria/' + slug} class="tl-post">
                    <span class={'tl-dot ' + post.data.category}></span>
                    <span class="tl-body">
                      <span class="tl-title">
                        {post.data.pinned && <span class="pin-mark">✦</span>}
                        {post.data.title}
                      </span>
                      {post.data.description && <span class="tl-desc">{post.data.description}</span>}
                    </span>
                    <span class="tl-meta">
                      <span class="tl-date">{post.data.date.slice(5).replace('-','/')}</span>
                      <span class={'tag ' + post.data.category}>{post.data.tags[0] ?? post.data.category}</span>
                    </span>
                  </a>
                );
              })}
            </div>
          ))}
        </div>
      );
    })}
  </div>
</div>
</Base>