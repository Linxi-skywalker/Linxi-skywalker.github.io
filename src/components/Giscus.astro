---
const { path } = Astro.props;
---
<div class="giscus-wrap">
  <script src="https://giscus.app/client.js"
        data-repo="Linxi-skywalker/Linxi-skywalker.github.io"
        data-repo-id="R_kgDOSJMneg"
        data-category="Announcements"
        data-category-id="DIC_kwDOSJMnes4C7ZnJ"
        data-mapping="pathname"
        data-strict="0"
        data-reactions-enabled="1"
        data-emit-metadata="0"
        data-input-position="bottom"
        data-theme="light"
        data-lang="zh-CN"
        crossorigin="anonymous"
        async>
  </script>
</div>


<style>
  .giscus-wrap {
    margin-top: 3rem;
    padding-top: 2rem;
    border-top: 1px solid var(--rule);
  }
  .giscus-wrap iframe {
    color-scheme: normal;
  }
</style>